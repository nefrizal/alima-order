<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KSM — Lacak Pesanan Anda</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
  :root{--brand:#C8521A;--bg:#faf7f4;--card:#fff;--text:#2a2a2a;--muted:#8a8378;--ok:#2f9e44;--warn:#e8590c;}
  *{box-sizing:border-box;margin:0;padding:0;font-family:'Segoe UI',Roboto,Arial,sans-serif;}
  body{background:var(--bg);color:var(--text);min-height:100vh;padding:16px;}
  .header{text-align:center;padding:16px 0;}
  .header h1{font-size:20px;color:var(--brand);}
  .header p{color:var(--muted);font-size:13px;margin-top:4px;}
  .card{max-width:480px;margin:0 auto 14px;background:var(--card);border-radius:14px;padding:16px;box-shadow:0 2px 10px rgba(0,0,0,.06);}
  .info-row{display:flex;justify-content:space-between;font-size:13px;padding:5px 0;border-bottom:1px solid #f1ece6;}
  .info-row:last-child{border-bottom:none;}
  .info-row span:first-child{color:var(--muted);}
  .info-row span:last-child{font-weight:600;}
  #map{width:100%;height:340px;border-radius:12px;margin-top:4px;}
  .status-badge{display:inline-block;font-size:12px;font-weight:700;padding:5px 12px;border-radius:20px;margin-bottom:10px;}
  .status-live{background:#eafbe7;color:var(--ok);}
  .status-stale{background:#fff3e0;color:var(--warn);}
  .status-off{background:#f1ece6;color:var(--muted);}
  .empty{text-align:center;color:var(--muted);padding:30px;}
  .refresh-note{font-size:11px;color:var(--muted);text-align:center;margin-top:8px;}
</style>
</head>
<body>

<div class="header">
  <h1>🛰️ Lacak Pesanan Anda</h1>
  <p>Posisi driver diperbarui otomatis setiap beberapa detik</p>
</div>

<div class="card" id="infoCard">
  <p class="empty">Memuat data pesanan…</p>
</div>

<div class="card hidden" id="mapCard" style="display:none;">
  <span class="status-badge status-off" id="statusBadge">Menghubungkan…</span>
  <div id="map"></div>
  <p class="refresh-note">Halaman ini otomatis refresh posisi tiap 10 detik.</p>
</div>

<script>
const API_URL = "https://script.google.com/macros/s/AKfycbyPgnhHNpbAWQbt4sNQiLFaDTRN-emDLn_rV68GVpvkdFAbFd41fyZxdMJUMqHdI1Zp/exec";
const params = new URLSearchParams(window.location.search);
const noOrder = params.get("no");

let map, driverMarker, dapurMarker, tujuanMarker;
let orderInfo = null;

function jsonp(url, p) {
  return new Promise((resolve) => {
    const cb = "cb_" + Date.now() + Math.random().toString(36).slice(2);
    window[cb] = (data) => { resolve(data); delete window[cb]; document.body.removeChild(script); };
    const qs = new URLSearchParams({...p, callback: cb}).toString();
    const script = document.createElement("script");
    script.src = url + "?" + qs;
    document.body.appendChild(script);
  });
}

async function init() {
  if (!noOrder) {
    document.getElementById("infoCard").innerHTML = '<p class="empty">Link tidak valid.</p>';
    return;
  }

  const res = await jsonp(API_URL, { action: "get_track_info", no: noOrder });
  if (!res.ok) {
    document.getElementById("infoCard").innerHTML = `<p class="empty">${res.error}</p>`;
    return;
  }
  orderInfo = res.order;

  document.getElementById("infoCard").innerHTML = `
    <div class="info-row"><span>No. Order</span><span>${res.order.no}</span></div>
    <div class="info-row"><span>Paket</span><span>${res.order.paket} (${res.order.qty})</span></div>
    <div class="info-row"><span>Alamat</span><span style="text-align:right;max-width:65%;">${res.order.alamat}</span></div>
  `;

  if (res.order.statusDelivery === "Diterima") {
    document.getElementById("infoCard").innerHTML += `<p style="margin-top:10px;color:var(--ok);font-weight:600;text-align:center;">✅ Pesanan sudah diterima. Terima kasih!</p>`;
    return; // tidak perlu tampilkan peta lagi
  }

  document.getElementById("mapCard").style.display = "block";
  initMap(res.dapur, res.tujuan);
  pollLokasi();
  setInterval(pollLokasi, 10000);
}

function initMap(dapur, tujuan) {
  map = L.map("map").setView([dapur.lat, dapur.lng], 13);
  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
    attribution: "© OpenStreetMap"
  }).addTo(map);

  dapurMarker = L.marker([dapur.lat, dapur.lng]).addTo(map).bindPopup("🏠 Dapur KSM");

  if (tujuan) {
    tujuanMarker = L.marker([tujuan.lat, tujuan.lng]).addTo(map).bindPopup("📍 Tujuan Anda");
  }
}

async function pollLokasi() {
  const res = await jsonp(API_URL, { action: "get_driver_location", no: noOrder });
  const badge = document.getElementById("statusBadge");

  if (!res.ok) {
    badge.className = "status-badge status-off";
    badge.textContent = "⏳ Driver belum mulai perjalanan";
    return;
  }

  const latlng = [res.lat, res.lng];
  if (!driverMarker) {
    const driverIcon = L.divIcon({
      html: '<div style="background:#C8521A;width:16px;height:16px;border-radius:50%;border:3px solid #fff;box-shadow:0 0 0 2px #C8521A;"></div>',
      className: "", iconSize: [16, 16]
    });
    driverMarker = L.marker(latlng, { icon: driverIcon }).addTo(map).bindPopup("🚗 Driver");
    map.setView(latlng, 14);
  } else {
    driverMarker.setLatLng(latlng);
  }

  if (res.stale) {
    badge.className = "status-badge status-stale";
    badge.textContent = `⚠️ Sinyal terakhir ${res.detikLalu} detik lalu`;
  } else {
    badge.className = "status-badge status-live";
    badge.textContent = "🟢 Live — driver sedang bergerak";
  }
}

init();
</script>
</body>
</html>
